---
import BaseLayout from './BaseLayout.astro';

export interface Props {
  title: string;
  description: string;
  eyebrow?: string;
  updatedAt: string;
}

const {
  title,
  description,
  eyebrow = 'Legal',
  updatedAt,
} = Astro.props;
---

<BaseLayout title={title} description={description}>
  <div class="legal-shell animate-fade-in">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M9 18l6-6-6-6" />
      </svg>
      <span>{title}</span>
    </nav>

    <header class="page-header">
      <span class="page-label">{eyebrow}</span>
      <h1>{title}</h1>
      <p class="page-description">{description}</p>
    </header>

    <div class="meta-card glass-card">
      <div class="meta-item">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
          <line x1="16" y1="2" x2="16" y2="6" />
          <line x1="8" y1="2" x2="8" y2="6" />
          <line x1="3" y1="10" x2="21" y2="10" />
        </svg>
        <span>Last updated: {updatedAt}</span>
      </div>
      <div class="meta-item">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M22 12h-4l-3 9L9 3l-3 9H2" />
        </svg>
        <span>Applies to borysonline.com and related Borys Online services</span>
      </div>
    </div>

    <article class="legal-content glass-card">
      <slot />
    </article>
  </div>
</BaseLayout>

<style>
  .legal-shell {
    max-width: 860px;
    margin: 0 auto;
    padding: 2rem 1rem 4rem;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 2rem;
    font-size: 0.9rem;
    color: var(--color-muted);
    flex-wrap: wrap;
  }

  .breadcrumb a {
    color: var(--color-accent);
  }

  .page-header {
    margin-bottom: 2rem;
  }

  .page-label {
    display: inline-block;
    margin-bottom: 0.6rem;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .page-header h1 {
    margin-bottom: 0.75rem;
    font-size: clamp(2.25rem, 5vw, 3.25rem);
  }

  .page-description {
    max-width: 62ch;
    font-size: 1.05rem;
    color: var(--color-muted);
  }

  .meta-card {
    display: flex;
    gap: 1rem 2rem;
    padding: 1rem 1.5rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .meta-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-muted);
    font-size: 0.95rem;
  }

  .legal-content {
    padding: 1.75rem;
    line-height: 1.8;
    font-size: 1.02rem;
  }

  .legal-content :global(h2) {
    margin-top: 2rem;
    margin-bottom: 0.85rem;
    font-size: 1.5rem;
  }

  .legal-content :global(h3) {
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
    font-size: 1.15rem;
  }

  .legal-content :global(p) {
    margin-bottom: 1rem;
  }

  .legal-content :global(ul),
  .legal-content :global(ol) {
    margin: 0 0 1rem 1.5rem;
  }

  .legal-content :global(li) {
    margin-bottom: 0.5rem;
  }

  @media (max-width: 768px) {
    .legal-shell {
      padding: 1.5rem 1rem 3rem;
    }

    .legal-content {
      padding: 1.25rem;
    }
  }
</style>